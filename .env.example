# Copie para .env e preencha. Os mesmos três valores devem existir como
# Environment Variables no projeto da Vercel (Production/Preview/Development).

# OAuth Client ID (Web) do Google Cloud Console — público, vai para o bundle.
GOOGLE_CLIENT_ID=

# Postgres (Railway) — segredo, usado só pelas funções em api/.
DATABASE_URL=

# Assinatura dos cookies de sessão — segredo. Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# O game server de co-op (server/) usa o MESMO valor para validar os tokens
# de /api/realtime-token — configure-o também no serviço da Railway.
JWT_SECRET=

# URL do game server de co-op, injetada no bundle em build time.
# Dev: deixe vazio (padrão ws://127.0.0.1:8138, suba com `npm run dev:server`).
# Produção (Vercel): WS_URL=wss://<serviço>.up.railway.app
WS_URL=

# Mercado Pago (loja de moedas — Pix) — segredos, usados só por api/shop/*.
# Painel: https://www.mercadopago.com.br/developers/panel/app
# MP_ACCESS_TOKEN: credencial de produção (Suas integrações → sua app → Credenciais).
#   Use a credencial de TESTE (TEST-...) pra validar o fluxo sem mexer com dinheiro real.
# MP_WEBHOOK_SECRET: gerado ao configurar a URL de notificação
#   (https://<seu-domínio>/api/shop/webhook) na mesma tela de Credenciais.
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
